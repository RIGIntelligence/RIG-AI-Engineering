#!/usr/bin/env bash
# RIG AI Engineering v15 — Unified CLI
# Usage: rig <command> [args]
#
# Prompt Intelligence:
#   rig fix-prompt [prompt]   Fix a rough prompt with RIG Prompt Master
#   rig fix [prompt]          Alias for fix-prompt
#   rig prompt-master [prompt] Alias for fix-prompt
#   rig design-prompt [prompt] Fix a Claude Design prompt with walkthrough defaults
#   rig enhance <prompt>       Analyze + enhance a prompt (auto-context, RIG doctrine)
#   rig score <prompt>         Detailed prompt scoring (0-100, 4 axes)
#   rig run <prompt>           Enhance → Execute via Hermes → Learn from outcome
#   rig ab-test "A" "B"        A/B test two prompt variants, declare winner
#   rig suggest <query>        Search 1000+ prompt templates
#   rig history [n]            Show last n prompts with scores
#   rig stats                  Personal prompting dashboard
#
# System:
#   rig app [--port 8765]      Start local RIG Prompt Master web app + API
#   rig check [--days n]       Audit all 5 harness sessions
#   rig prompt [prompt]        Score a prompt (pipe or argument)
#   rig refresh                Refresh coaching context in CLAUDE.md/AGENTS.md
#   rig install                Install dependencies
#   rig archon                 List Archon workflows
#   rig catalog [section]      Show OSS resources, persona agents, or questions
#   rig v15 [command]          Run v15 operator catalog/intake/proof workflows
#   rig context-status         Check QNAP/GitHub/Gitea/Recall context adapters
#
# Quick:
#   rig doctor                 Diagnose prompting health
#   rig template <key>         Fill a built-in template

set -euo pipefail

RIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$RIG_DIR/scripts"

# Resolve RIG_DIR: if installed globally, find the repo
if [[ ! -d "$RIG_DIR/scripts" ]]; then
    # Try common locations
    for try in "$HOME/RIG-AI-Engineering" "$HOME/.rig/RIG-AI-Engineering" "/usr/local/share/rig"; do
        if [[ -d "$try/scripts" ]]; then
            RIG_DIR="$try"
            break
        fi
    done
fi

PYTHON_DIR="$RIG_DIR/python"
ARCHON_DIR="$RIG_DIR/archon"
ENGINE="$PYTHON_DIR/rig/prompt_engine.py"
V15="$PYTHON_DIR/rig/rig_v15.py"
FIXER="$PYTHON_DIR/rig/rig_prompt_fixer.py"
APP="$PYTHON_DIR/rig/rig_app_server.py"

# Ensure Python engine is available
if [[ ! -f "$ENGINE" ]]; then
    echo "ERROR: Prompt engine not found at $ENGINE"
    echo "Run: rig install"
    exit 1
fi

# ─── Prompt Intelligence (Python Engine) ────────────────────────────
cmd_enhance() {
    python3 "$ENGINE" enhance "$*"
}

cmd_fix_prompt() {
    if [[ ! -f "$FIXER" ]]; then
        echo "ERROR: RIG Prompt Master not found at $FIXER"
        echo "Run: rig install"
        return 1
    fi
    python3 "$FIXER" "$@"
}

cmd_prompt_master() {
    cmd_fix_prompt "$@"
}

cmd_design_prompt() {
    cmd_fix_prompt --mode claude-design "$@"
}

cmd_context_status() {
    if [[ ! -f "$FIXER" ]]; then
        echo "ERROR: RIG Prompt Master not found at $FIXER"
        echo "Run: rig install"
        return 1
    fi
    python3 "$FIXER" --status "$@"
}

cmd_app() {
    if [[ ! -f "$APP" ]]; then
        echo "ERROR: RIG Prompt Master server not found at $APP"
        echo "Run: rig install"
        return 1
    fi
    python3 "$APP" "$@"
}

cmd_score() {
    python3 "$ENGINE" score "$*"
}

cmd_run() {
    local tool="hermes"
    local timeout="300"
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tool) tool="$2"; shift 2 ;;
            --timeout) timeout="$2"; shift 2 ;;
            --*) shift 2 ;;
            *) args+=("$1"); shift ;;
        esac
    done
    python3 "$ENGINE" run "${args[*]}" --tool "$tool" --timeout "$timeout"
}

cmd_learn() {
    python3 "$ENGINE" learn "$@"
}

cmd_coach() {
    python3 "$ENGINE" coach
}

cmd_trends() {
    local days="${1:-30}"
    python3 "$ENGINE" trends --days "$days"
}

cmd_sessions() {
    local harness="${1:-hermes}"
    local limit="${2:-10}"
    python3 "$ENGINE" sessions --harness "$harness" --limit "$limit"
}

cmd_ab_test() {
    local tool="hermes"
    local timeout="300"
    local args_a=""
    local args_b=""
    local separator_found=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tool) tool="$2"; shift 2 ;;
            --timeout) timeout="$2"; shift 2 ;;
            --) separator_found=true; shift ;;
            *) if [[ "$separator_found" == "false" ]]; then
                   args_a="$args_a $1"
               else
                   args_b="$args_b $1"
               fi
               shift ;;
        esac
    done
    python3 "$ENGINE" ab-test "$(echo "$args_a" | xargs)" "$(echo "$args_b" | xargs)" --tool "$tool" --timeout "$timeout"
}

# ─── Watcher Daemon ──────────────────────────────────────────────────
WATCHER="$RIG_DIR/python/rig/rig-watch.py"

cmd_watch() {
    local subcmd="${1:-scan}"
    shift 2>/dev/null || true
    python3 "$WATCHER" "$subcmd" "$@"
}

cmd_proxy() {
    python3 "$RIG_DIR/python/rig/rig-proxy.py" "$@"
}

cmd_suggest() {
    python3 "$ENGINE" suggest "$*"
}

cmd_history() {
    local limit="${1:-10}"
    python3 "$ENGINE" history --limit "$limit"
}

cmd_stats() {
    python3 "$ENGINE" stats
}

cmd_validate() {
    python3 "$ENGINE" validate
}

cmd_report() {
    local days="${1:-7}"
    python3 "$ENGINE" report --days "$days"
}

# ─── System Commands (Shell) ────────────────────────────────────────
cmd_check() {
    zsh "$SCRIPTS_DIR/ai-coach-check.sh" "$@"
}

cmd_prompt() {
    if [[ -t 0 ]]; then
        # Argument mode
        python3 "$ENGINE" score "${1:-}"
    else
        # Pipe mode
        local input
        input=$(cat)
        python3 "$ENGINE" score "$input"
    fi
}

cmd_refresh() {
    zsh "$SCRIPTS_DIR/ai-coach-refresh.sh" "$@"
}

cmd_install() {
    echo "==> Installing RIG AI Engineering..."
    zsh "$SCRIPTS_DIR/dev-install.sh"
    echo ""
    echo "==> Done. Run 'rig refresh' to load coaching context."
}

cmd_archon() {
    echo "Archon commands:"
    ls -1 "$ARCHON_DIR/commands/" 2>/dev/null | sed 's/^/  /'
    echo ""
    echo "Archon workflows:"
    ls -1 "$ARCHON_DIR/workflows/" 2>/dev/null | sed 's/^/  /'
}

cmd_catalog() {
    local section="${1:-guide}"
    case "$section" in
        resources|resource|repos|harnesses)
            sed -n '1,260p' "$RIG_DIR/catalogs/open-source-agent-harnesses.yaml"
            ;;
        personas|persona|agents)
            sed -n '1,260p' "$RIG_DIR/catalogs/rig-methodology-persona-agents.yaml"
            ;;
        questions|question-bank|intake)
            sed -n '1,520p' "$RIG_DIR/catalogs/rig-methodology-question-bank.yaml"
            ;;
        guide|help|"")
            sed -n '1,220p' "$RIG_DIR/docs/rig-open-source-expansion.md"
            ;;
        *)
            echo "Unknown catalog section: $section"
            echo "Use: rig catalog [resources|personas|questions]"
            return 1
            ;;
    esac
}

cmd_v15() {
    if [[ ! -f "$V15" ]]; then
        echo "ERROR: v15 operator layer not found at $V15"
        echo "Run: rig install"
        return 1
    fi
    python3 "$V15" "$@"
}

# ─── Quick Commands ─────────────────────────────────────────────────
cmd_doctor() {
    echo "═══════════════════════════════════════════════════"
    echo "  RIG PROMPT DOCTOR — System Health Check"
    echo "═══════════════════════════════════════════════════"
    echo ""

    # Check Python
    if command -v python3 &>/dev/null; then
        echo "  [OK] Python 3: $(python3 --version)"
    else
        echo "  [FAIL] Python 3 not found"
    fi

    # Check engine
    if [[ -f "$ENGINE" ]]; then
        echo "  [OK] Prompt engine: $ENGINE"
    else
        echo "  [FAIL] Prompt engine missing"
    fi

    if [[ -f "$V15" ]]; then
        echo "  [OK] v15 operator layer: $V15"
    else
        echo "  [FAIL] v15 operator layer missing"
    fi

    if [[ -f "$FIXER" ]]; then
        echo "  [OK] RIG Prompt Master: $FIXER"
    else
        echo "  [FAIL] RIG Prompt Master missing"
    fi

    if [[ -f "$APP" ]]; then
        echo "  [OK] Prompt Master app: $APP"
    else
        echo "  [FAIL] Prompt Master app missing"
    fi

    if python3 -c 'import yaml' 2>/dev/null; then
        echo "  [OK] PyYAML: available"
    else
        echo "  [FAIL] PyYAML missing; install with: python3 -m pip install PyYAML"
    fi

    # Check history
    local hist_file="$HOME/.rig/prompt-history.jsonl"
    if [[ -f "$hist_file" ]]; then
        local count=$(wc -l < "$hist_file" | tr -d ' ')
        echo "  [OK] Prompt history: $count entries"
    else
        echo "  [--] No prompt history yet"
    fi

    # Check harness parsers
    echo ""
    echo "  HARNESS SESSIONS:"
    local harnesses=("claude:~/.claude/projects" "codex:~/.codex/sessions" "hermes:~/.hermes/sessions" "gsd:~/.gsd/sessions")
    for h in "${harnesses[@]}"; do
        local name="${h%%:*}"
        local path="${h#*:}"
        path="${path/#\~/$HOME}"
        if [[ -d "$path" ]]; then
            local count=$(find "$path" -name "*.json*" -type f 2>/dev/null | wc -l | tr -d ' ')
            echo "    $name: $count sessions"
        else
            echo "    $name: not found"
        fi
    done

    # Check rules
    local rules_dir="$HOME/.ai-engineer-coach/rules"
    if [[ -d "$rules_dir" ]]; then
        local rule_count=$(ls "$rules_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
        echo ""
        echo "  [OK] Custom rules: $rule_count"
    fi

    # Personal stats
    echo ""
    python3 "$ENGINE" stats 2>/dev/null || echo "  Run 'rig stats' for personal dashboard"
}

cmd_template() {
    local key="${1:-}"
    if [[ -z "$key" ]]; then
        echo "Available templates:"
        echo "  code-review    Code review with RIG standards"
        echo "  bug-fix        Bug fix with verification"
        echo "  deploy         Deploy to fleet"
        echo "  research       Research task with synthesis"
        echo "  prompt-coach   Score and improve a prompt"
        echo ""
        echo "Usage: rig template <key>"
        return
    fi

    case "$key" in
        code-review)
            echo "## Context
- File: <path>
- Branch: <branch>

## Review Criteria
- [ ] Follows project conventions
- [ ] Error handling complete
- [ ] Tests included
- [ ] No banned words
- [ ] Under <N> lines

## Output
- Summary of findings
- Critical issues (must fix)
- Suggestions (nice to have)
- Verdict: approve / request changes"
            ;;
        bug-fix)
            echo "[D1 — Direct]

## Bug
<describe the issue>

## Context
- File: <path>
- Error: <error message>
- Reproduction: <steps>

## Fix
- Root cause:
- Implementation:
- Edge cases:

## Verification
- [ ] Reproduction case passes
- [ ] Unit tests added
- [ ] No regressions"
            ;;
        deploy)
            echo "[L5 — Launch]

## Deployment
- Target: <nodes>
- Model/Service: <name>
- Version: <version>

## Steps
1. Pre-flight checks
2. Deploy to staging
3. Verify staging
4. Deploy to production nodes
5. Post-deploy verification

## Rollback Plan
- Trigger: <condition>
- Steps: <rollback steps>

## Verification
- [ ] All nodes healthy
- [ ] Response time < <N>ms
- [ ] Error rate < <N>%"
            ;;
        research)
            echo "[L2 — Learn]

## Research Question
<question>

## Context
- Domain: <domain>
- Prior work: <references>
- Constraints: <limits>

## Method
1. Search sources
2. Synthesize findings
3. Identify gaps
4. Recommendations

## Output Format
- Executive summary (3 bullets)
- Detailed findings
- Confidence level: high/medium/low
- Next steps"
            ;;
        prompt-coach)
            echo "## Prompt to Review
<paste prompt here>

## Scoring Criteria
- Specificity (0-25): file paths, numbers, constraints, output format
- RIG Doctrine (0-25): lattice coords, success criteria, verification
- Context (0-25): file references, skills, prior sessions
- Actionability (0-25): verbs, sequencing, conditions

## Output
- Total score (0-100)
- Grade (A+ to F)
- Top 3 improvements
- Enhanced prompt suggestion"
            ;;
        *)
            echo "Unknown template: $key"
            echo "Run 'rig template' to see available templates."
            ;;
    esac
}

