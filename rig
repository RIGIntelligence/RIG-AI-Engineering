# ─── Main Router ────────────────────────────────────────────────────
case "${1:-help}" in
    fix-prompt|fix) shift; cmd_fix_prompt "$@" ;;
    prompt-master|master) shift; cmd_prompt_master "$@" ;;
    design-prompt|claude-design) shift; cmd_design_prompt "$@" ;;
    app)        shift; cmd_app "$@" ;;
    context-status) shift; cmd_context_status "$@" ;;
    enhance)    shift; cmd_enhance "$@" ;;
    score)      shift; cmd_score "$@" ;;
    run)        shift; cmd_run "$@" ;;
    ab-test)    shift; cmd_ab_test "$@" ;;
    learn)      shift; cmd_learn "$@" ;;
    coach)      cmd_coach ;;
    trends)     shift; cmd_trends "$@" ;;
    sessions)   shift; cmd_sessions "$@" ;;
    validate)   cmd_validate ;;
    report)     shift; cmd_report "$@" ;;
    watch)      shift; cmd_watch "$@" ;;
    proxy)      shift; cmd_proxy "$@" ;;
    suggest)    shift; cmd_suggest "$@" ;;
    history)    shift; cmd_history "$@" ;;
    stats)      cmd_stats ;;
    check)      shift; cmd_check "$@" ;;
    prompt)     shift; cmd_prompt "$@" ;;
    refresh)    shift; cmd_refresh "$@" ;;
    install)    cmd_install ;;
    archon)     cmd_archon ;;
    catalog)    shift; cmd_catalog "$@" ;;
    v15)        shift; cmd_v15 "$@" ;;
    doctor)     cmd_doctor ;;
    template)   shift; cmd_template "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        if [[ -n "${1:-}" ]]; then
            cmd_enhance "$@"
        else
            cmd_help
            exit 1
        fi
        ;;
esac
