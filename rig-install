#!/usr/bin/env bash
# RIG AI Engineering System Installer
# Usage: rig-install [--global|--user|--help]

set -euo pipefail

RIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_TYPE="user"  # default to user install
BIN_DIR="$HOME/bin"
FORCE=false
RIG_SCRIPT="$RIG_DIR/rig"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --global)
            INSTALL_TYPE="global"
            BIN_DIR="/usr/local/bin"
            shift
            ;;
        --user)
            INSTALL_TYPE="user"
            BIN_DIR="$HOME/bin"
            shift
            ;;
        --launchd)
            INSTALL_TYPE="launchd"
            shift
            ;;
        --mcp)
            INSTALL_TYPE="mcp"
            shift
            ;;
        --hook)
            INSTALL_TYPE="hook"
            shift
            ;;
        --force)
            FORCE=true
            shift
            ;;
        --help|-h)
            echo "RIG AI Engineering System Installer"
            echo ""
            echo "Usage: rig-install [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --user        Install to user bin directory ($HOME/bin) [default]"
            echo "  --global      Install to system bin directory (/usr/local/bin) [requires sudo]"
            echo "  --force       Overwrite existing installation"
            echo "  --help, -h    Show this help message"
            echo ""
            echo "Examples:"
            echo "  rig-install           # Install to ~/bin/rig"
            echo "  rig-install --global  # Install to /usr/local/bin/rig (requires sudo)"
            echo "  rig-install --force   # Force reinstall"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use rig-install --help for usage information"
            exit 1
            ;;
    esac
done

if [[ ! -f "$RIG_SCRIPT" ]]; then
    echo "ERROR: rig entrypoint not found at $RIG_SCRIPT"
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "ERROR: python3 is required but was not found in PATH."
    echo "Install Python 3.10+ and rerun rig-install."
    exit 1
fi

if [[ "$INSTALL_TYPE" == "global" && ! -w "$BIN_DIR" ]]; then
    echo "ERROR: $BIN_DIR is not writable."
    echo "Rerun with sudo (e.g., sudo ./rig-install --global) or use --user."
    exit 1
fi

# Create bin directory if it doesn't exist
mkdir -p "$BIN_DIR"

# Install rig CLI
RIG_TARGET="$BIN_DIR/rig"

if [[ -f "$RIG_TARGET" && "$FORCE" != "true" ]]; then
    read -p "rig CLI already exists at $RIG_TARGET. Overwrite? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Installation cancelled."
        exit 1
    fi
fi

echo "Installing rig CLI to $RIG_TARGET..."
cp "$RIG_SCRIPT" "$RIG_TARGET"
chmod +x "$RIG_TARGET"

# Verify installation
if "$RIG_TARGET" --help >/dev/null 2>&1; then
    echo ""
    echo "✅ RIG AI Engineering installed successfully!"
    echo "Installed binary: $RIG_TARGET"
    echo ""
    echo "To get started:"
    echo "  rig check          # Audit your AI engineering sessions"
    echo "  rig suggest 'your task'  # Find prompt templates"
    echo "  rig prompt         # Score a prompt for quality"
    echo ""
    echo "Run 'rig --help' for all commands."
else
    echo ""
    echo "⚠️  Installation complete, but rig command not found in PATH."
    echo "   Add $BIN_DIR to your PATH or restart your terminal."
    echo ""
    echo "To add to PATH permanently, add this to your ~/.zshrc or ~/.bashrc:"
    echo "  export PATH=\"$BIN_DIR:\$PATH\""
fi

# Post-install hints
echo ""
echo "💡 Tips:"
echo "  - Run 'rig refresh' every few hours to update coaching context"
echo "  - Run 'rig check --days 7' weekly to review harness usage"
echo "  - All prompt templates are in $RIG_DIR/prompt-templates/"
echo "  - Archon workflows are in $RIG_DIR/archon/ for automation"
echo "  - Install hermes hook: rig-install --hook"
echo "  - MCP server: rig-install --mcp"

# ─── Hook Installation ───────────────────────────────────────────────
if [[ "$INSTALL_TYPE" == "hook" ]]; then
    hook_file="$RIG_DIR/rig-hook.zsh"
    if [[ ! -f "$hook_file" ]]; then
        echo "ERROR: rig-hook.zsh not found at $hook_file"
        exit 1
    fi

    # Add to .zshrc if not already present
    zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        if grep -q "rig-hook.zsh" "$zshrc"; then
            echo "Hook already sourced in $zshrc"
        else
            echo "" >> "$zshrc"
            echo "# RIG AI Engineering — Hermes pre-send hook" >> "$zshrc"
            echo "source \"$hook_file\" 2>/dev/null" >> "$zshrc"
            echo "Hook installed in $zshrc"
        fi
        echo ""
        echo "To activate: source $zshrc"
        echo "To enable:   rig-hook-on"
        echo "To disable:  rig-hook-off"
    else
        echo "No .zshrc found. Add this manually:"
        echo "  source \"$hook_file\""
        echo "Then: rig-hook-on"
    fi
fi

# ─── MCP Server Installation ─────────────────────────────────────────
if [[ "$INSTALL_TYPE" == "mcp" ]]; then
    MCP_SERVER="$RIG_DIR/python/rig/rig-mcp-server.py"
    if [[ ! -f "$MCP_SERVER" ]]; then
        echo "ERROR: rig-mcp-server.py not found at $MCP_SERVER"
        exit 1
    fi

    if ! python3 -c "import yaml" >/dev/null 2>&1; then
        echo "ERROR: Missing Python dependency: pyyaml"
        echo "Install it with: python3 -m pip install pyyaml"
        exit 1
    fi

    if python3 -c "
import yaml
from pathlib import Path
config_path = Path.home() / '.hermes' / 'config.yaml'
if config_path.exists():
    with open(config_path) as f:
        config = yaml.safe_load(f)
    # Check both key names
    servers = config.get('mcp_servers') or config.get('mcpServers') or {}
    if 'rig' in servers:
        print('ALREADY_INSTALLED')
    else:
        print('NOT_INSTALLED')
else:
    print('NO_CONFIG')
" 2>/dev/null | grep -q "ALREADY_INSTALLED"; then
        echo "RIG MCP server already configured in hermes"
    else
        python3 -c "
import yaml
from pathlib import Path
config_path = Path.home() / '.hermes' / 'config.yaml'
with open(config_path) as f:
    config = yaml.safe_load(f)
# Use whatever key already exists, or default to mcp_servers
if 'mcp_servers' in config:
    key = 'mcp_servers'
elif 'mcpServers' in config:
    key = 'mcpServers'
else:
    key = 'mcp_servers'
config[key] = config.get(key) or {}
config[key]['rig'] = {
    'command': 'python3',
    'args': ['$MCP_SERVER'],
    'description': 'RIG AI Engineering v10 — Prompt Intelligence',
    'timeout': 120,
    'connect_timeout': 60,
    'enabled': True,
}
with open(config_path, 'w') as f:
    yaml.dump(config, f, default_flow_style=False, allow_unicode=True)
print('INSTALLED')
"
        echo "RIG MCP server installed. Restart hermes to activate."
    fi
fi

# ─── Launchd Service Installation ────────────────────────────────────
if [[ "$INSTALL_TYPE" == "launchd" ]]; then
    if [[ "$(uname -s)" != "Darwin" ]]; then
        echo "ERROR: --launchd is only supported on macOS."
        exit 1
    fi

    if ! command -v launchctl >/dev/null 2>&1; then
        echo "ERROR: launchctl not found; cannot install launchd service."
        exit 1
    fi

    PLIST_NAME="com.rig.watcher"
    PLIST_SRC="$RIG_DIR/assets/$PLIST_NAME.plist"
    PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"
    WATCHER_PATH="$RIG_DIR/python/rig/rig-watch.py"
    RIG_DIR_ESC="${RIG_DIR// /\ }"
    HOME_ESC="${HOME// /\ }"

    if [[ ! -f "$PLIST_SRC" ]]; then
        echo "ERROR: plist template not found at $PLIST_SRC"
        exit 1
    fi

    # Generate plist with correct paths
    sed -e "s|{RIG_WATCHER_PATH}|$WATCHER_PATH|g" \
        -e "s|{RIG_DIR}|$RIG_DIR_ESC|g" \
        -e "s|{HOME}|$HOME_ESC|g" \
        "$PLIST_SRC" > "$PLIST_DST"

    # Unload if already loaded
    launchctl unload "$PLIST_DST" 2>/dev/null

    # Load
    launchctl load "$PLIST_DST"
    echo "Launchd service installed: $PLIST_NAME"
    echo "  Plist: $PLIST_DST"
    echo "  Logs:  $RIG_DIR/watcher/stdout.log"
    echo ""
    echo "Commands:"
    echo "  launchctl start $PLIST_NAME"
    echo "  launchctl stop $PLIST_NAME"
    echo "  rig watch status"
    echo "  rig watch scan"
fi